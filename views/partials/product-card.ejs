<%
/*
  Parámetros: title, price, ingredients, description, schedule, imgLabel, imgSrc (opcional)
*/
const _imgSrc = typeof imgSrc !== 'undefined' ? imgSrc : null;
%>
<div class="w-[260px] sm:w-[350px] flex-shrink-0 bg-cafe/25 rounded-lg overflow-hidden flex flex-col">
  <div class="bg-beige-light aspect-[4/3] overflow-hidden flex items-center justify-center p-4">
    <img
      src="<%= _imgSrc %>"
      alt="<%= title %>"
      class="w-full h-full object-contain"
    >
    <p class="text-xs break-all text-red-600"><%= _imgSrc %></p>
  </div>
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-baseline justify-between gap-2 mb-2">
      <h3 class="font-fraunces text-base leading-snug"><%= title %></h3>
      <% if (price) { %><span class="font-fraunces text-sm whitespace-nowrap">$ <%= price %></span><% } %>
    </div>
    <% if (ingredients) { %><p class="text-xs mb-3"><%= ingredients %></p><% } %>
    <p class="text-sm leading-relaxed mb-4"><%= description %></p>
    <p class="text-[11px] mt-auto uppercase tracking-widest2"><%= schedule %></p>
  </div>
</div>
