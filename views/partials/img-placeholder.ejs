<%
// Bloque de imagen: si se pasa imgSrc, muestra la foto real (object-cover).
// Si no, muestra un bloque decorativo de relleno (para cuando aún no hay foto).
const _ratio = typeof ratio !== 'undefined' ? ratio : 'aspect-[4/5]';
const _rounded = typeof rounded !== 'undefined' ? rounded : 'rounded-xl';
const _label = typeof label !== 'undefined' ? label : '';
const _imgSrc = typeof imgSrc !== 'undefined' ? imgSrc : null;
const _alt = typeof alt !== 'undefined' ? alt : _label;
%>
<% if (_imgSrc) { %>
  <div class="<%= _ratio %> <%= _rounded %> w-full overflow-hidden">
    <img src="<%= _imgSrc %>" alt="<%= _alt %>" class="w-full h-full object-cover" />
  </div>
<% } else { %>
  <div class="<%= _ratio %> <%= _rounded %> w-full bg-gradient-to-br from-cafe-light to-verde/40 flex flex-col items-center justify-center gap-2 overflow-hidden">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" class="text-beige-light/90">
      <path d="M12 3C9 7 6 10 6 14a6 6 0 0 0 12 0c0-4-3-7-6-11z" stroke="currentColor" stroke-width="1.4"/>
    </svg>
    <% if (_label) { %>
      <span class="font-fraunces text-[10px] tracking-widest2 uppercase text-beige-light/90 px-3 text-center"><%= _label %></span>
    <% } %>
  </div>
<% } %>
