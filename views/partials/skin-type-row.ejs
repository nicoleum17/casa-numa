<%
const _reverse = typeof reverse !== 'undefined' ? reverse : false;
%>

<div class="grid grid-cols-3 gap-4 items-stretch">

  <!-- IMAGEN -->
  <div class="col-span-1 rounded-lg overflow-hidden aspect-auto sm:h-[425px] <%= _reverse ? 'order-2' : 'order-1' %>">
    <img
      src="<%= imgSrc %>"
      alt="<%= title %>"
      class="w-full h-full min-h-[220px] object-cover"
    >
  </div>

  <!-- TEXTO -->
  <div class="col-span-2 rounded-lg overflow-hidden bg-verde/60 flex flex-col justify-center py-8 px-10 <%= _reverse ? 'order-1' : 'order-2' %>">
    <h3 class="font-anticdidone text-xl sm:text-2xl mb-3">
      <%= title %>
    </h3>

    <p class="text-sm sm:text-base leading-relaxed">
      <%= description %>
    </p>
  </div>

</div>