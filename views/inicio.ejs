<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { title: 'Casa Numa · Inicio' }) %>
</head>
<body>
  <%- include('partials/header', { active: 'inicio' }) %>

  <%- include('partials/hero', { heroEyebrow: 'Skin Studio', heroImgSrc: '/images/head/inicio.jpg', heroImgLabel: 'Toallas, velas y piedras de spa' }) %>

  <!-- BY FATIMA -->
  <section class="text-center pt-10 sm:pt-14 px-5">
    <p class="font-fraunces tracking-wide text-lg sm:text-xl text-tinta">by Fatima Sánchez</p>
    <p class="font-fraunces text-lg sm:text-xl text-tinta">Dermocosmetóloga Cosmiatra</p>
  </section>

  <!-- ACERCA DE MI -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-10 sm:py-14">
    <div class="section-title-wrap"><span class="section-title-text">Acerca de Mí</span></div>
    <div class="grid sm:grid-cols-[1fr_1.4fr] gap-8 sm:gap-12 items-center">
      <div class="max-w-[260px] mx-auto sm:mx-0 w-full">
        <img src="/images/inicio/fati.jpeg" alt="Fátima-Sánchez">
      </div>
      <div class="text-center sm:text-left">
        <p class="text-lg sm:text-xl">
          ¡Hola! Soy Fátima Monserrat, Dermocosmetóloga Cosmiatra y Terapeuta Spa, egresada del
          Instituto INESCI Morelia.
        </p>
        <p class="text-lg sm:text-xl mt-4">
          En Casa Numa encontrarás un espacio donde el cuidado de la piel y el bienestar, siempre
          con un equilibrio profesional y humano.
        </p>

        <div class='mt-8 space-y-4 pt-5'>
          <div class='flex items-center gap-3'>
            <span class='flex h-8 w-8 items-center justify-center rounded-full bg-verde/20'>
              <svg width='18' height='18' viewBox='0 0 24 24' fill='none'
                  stroke='#6F6B3D' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'
                  aria-hidden='true'>
                <path d='M5 13l4 4L19 7'/>
              </svg>
            </span>
            <span class='font-fraunces text-base sm:text-lg'>Dermocosmetología 2024</span>
          </div>

          <div class='flex items-center gap-3'>
            <span class='flex h-8 w-8 items-center justify-center rounded-full bg-verde/20'>
              <svg width='18' height='18' viewBox='0 0 24 24' fill='none'
                  stroke='#6F6B3D' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'
                  aria-hidden='true'>
                <path d='M5 13l4 4L19 7'/>
              </svg>
            </span>
            <span class='font-fraunces text-base sm:text-lg'>Cosmiatría Dermatológica 2025</span>
          </div>

          <div class='flex items-center gap-3'>
            <span class='flex h-8 w-8 items-center justify-center rounded-full bg-verde/20'>
              <svg width='18' height='18' viewBox='0 0 24 24' fill='none'
                  stroke='#6F6B3D' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'
                  aria-hidden='true'>
                <path d='M5 13l4 4L19 7'/>
              </svg>
            </span>
            <span class='font-fraunces text-base sm:text-lg'>Terapeuta Spa 2026</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="pt-4 pb-4">
    <div class="section-title-wrap"><span class="section-title-text">Servicios</span></div>
    <div class="flex flex-col gap-6 sm:gap-8 sm:max-w-5xl sm:mx-auto sm:px-8">
      <a href="/servicios/faciales" class="group block relative overflow-hidden aspect-[4/3] sm:aspect-[21/9]">
        <img src="/images/inicio/Tratamientos/Faciales.jpg" alt="faciales-casa-numa" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-tinta/25 flex items-center justify-center">
          <span class="font-fraunces text-3xl sm:text-4xl text-beige-light group-hover:scale-105 transition-transform">Faciales</span>
        </div>
      </a>
      <a href="/servicios/spa" class="group block relative overflow-hidden aspect-[4/3] sm:aspect-[21/9]">
        <img src="/images/inicio/Tratamientos/Spa.jpg" alt="spa-casa-numa" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-tinta/25 flex items-center justify-center">
          <span class="font-fraunces text-3xl sm:text-4xl text-beige-light group-hover:scale-105 transition-transform">Spa</span>
        </div>
      </a>
      <a href="/servicios/productos" class="group block relative overflow-hidden aspect-[4/3] sm:aspect-[21/9]">
        <%- include('partials/img-placeholder', { label: 'Productos de cuidado facial', ratio: 'h-full', rounded: 'rounded-none' }) %>
        <div class="absolute inset-0 bg-tinta/25 flex items-center justify-center">
          <span class="font-fraunces text-3xl sm:text-4xl text-beige-light group-hover:scale-105 transition-transform">Productos</span>
        </div>
      </a>
    </div>
  </section>

  <%- include('partials/cta-reserva') %>

  <!-- CARRUSEL -->
  <section class="py-10 sm:py-14">
    <div class="max-w-4xl mx-auto px-5 sm:px-8">
      <%- include('partials/carousel', {
        id: 'inicio-carousel',
        slides: [
          { label: 'Ritual de masaje y velas' },
          { label: 'Ambiente Casa Numa' },
          { label: 'Momento de relajación' }
        ]
      }) %>
    </div>
  </section>

  <div id="contacto"></div>
  <%- include('partials/footer') %>
</body>
</html>
