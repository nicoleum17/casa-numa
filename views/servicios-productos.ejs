<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { title: 'Casa Numa · Productos' }) %>
</head>
<body>
  <%- include('partials/header', { active: 'servicios-productos' }) %>

  <%- include('partials/hero', { heroEyebrow: 'Skin Studio', heroImgSrc: null, heroImgLabel: 'Línea de productos para el cuidado de la piel' }) %>

  <!-- CUIDADO INTELIGENTE -->
  <section class="max-w-3xl mx-auto px-5 sm:px-8 py-10 sm:py-14">
    <div class="section-title-wrap"><span class="section-title-text">Cuidado inteligente para tu piel</span></div>
    <p class="text-sm sm:text-base text-tinta/85 leading-relaxed">
      <strong class="text-tinta">Importante:</strong><br /><br>
      Todos los productos son de recomendación personalizada y deben utilizarse únicamente bajo
      valoración e indicación profesional para garantizar un uso seguro y efectivo.
    </p>
    <p class="text-sm sm:text-base text-tinta/85 leading-relaxed mt-4">
      Antes de realizar tu compra, consulta la disponibilidad de los productos. En caso de no
      contar con existencias, el tiempo aproximado de entrega es de 4 a 6 días hábiles.
    </p>
  </section>

  <!-- FRANJA DE MANOS CON PRODUCTOS -->
  <section class="bg-cafe-light">
    <div class="grid grid-cols-3 sm:grid-cols-6">
      <%- include('partials/img-placeholder', { label: 'Disco desmaquillante', ratio: 'aspect-square', rounded: 'rounded-none' }) %>
      <%- include('partials/img-placeholder', { label: 'Crema en tubo', ratio: 'aspect-square', rounded: 'rounded-none' }) %>
      <%- include('partials/img-placeholder', { label: 'Sérum gotero', ratio: 'aspect-square', rounded: 'rounded-none' }) %>
      <%- include('partials/img-placeholder', { label: 'Bomba dosificadora', ratio: 'aspect-square', rounded: 'rounded-none' }) %>
      <%- include('partials/img-placeholder', { label: 'Crema en frasco', ratio: 'aspect-square', rounded: 'rounded-none' }) %>
      <%- include('partials/img-placeholder', { label: 'Tubo de crema corporal', ratio: 'aspect-square', rounded: 'rounded-none' }) %>
    </div>
  </section>

  <!-- PRODUCTOS / MARCAS (da clic para ver el catálogo completo por gama) -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 py-12 sm:py-16">
    <div class="section-title-wrap"><span class="section-title-text">Productos</span></div>

    <div class="grid sm:grid-cols-3 gap-5 sm:gap-6">
      <% marcas.forEach(function(m){ %>
        <a href="/servicios/por-gama/<%= m.slug %>" class="group block">
          <%- include('partials/img-placeholder', { imgSrc: marcaImagen[m.slug], label: m.nombre, ratio: 'aspect-square', rounded: 'rounded-lg' }) %>
          <p class="font-fraunces text-center mt-3 text-tinta group-hover:opacity-70 transition-opacity"><%= m.nombre %></p>
        </a>
      <% }) %>
    </div>
  </section>

  <%- include('partials/cta-reserva') %>

  <div id="contacto"></div>
  <%- include('partials/footer') %>
</body>
</html>
