<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { title: 'Casa Numa · Spa' }) %>
</head>
<body>
  <%- include('partials/header', { active: 'servicios-spa' }) %>

  <%- include('partials/hero', { heroEyebrow: 'Skin Studio', heroImgSrc: '/images/head/Spa.jpg', heroImgLabel: 'Masaje con piedras y aceites' }) %>

  <!-- REGALATE UNA PAUSA -->
  <section class="max-w-3xl mx-auto px-5 sm:px-8 pt-10 sm:pt-14 text-center">
    <div class="section-title-wrap"><span class="section-title-text">Regálate una pausa, te lo mereces</span></div>
    <p class="text-sm sm:text-base text-tinta/85 leading-relaxed">
      La relajación a través de masajes reduce el estrés y disminuye el dolor muscular y las
      contracturas. Estos beneficios se logran al estimular la circulación sanguínea, liberar la
      tensión acumulada y disminuir la hormona cortisol, fomentando así un mejor estado de ánimo
      y un descanso profundo.
    </p>
  </section>

  <!-- FOTO DIVISORIA -->
  <section class="my-10 sm:my-14">
    <img src="/images/divisoras/div-spa.jpg" alt="Casa Numa · spa" class="w-full h-auto sm:h-[420px] object-cover" />
  </section>

  <!-- TRATAMIENTOS SPA -->
  <section class="max-w-5xl mx-auto px-5 sm:px-8 pb-12 sm:pb-16">
    <div class="section-title-wrap"><span class="section-title-text">Tratamientos Spa</span></div>

    <% tratamientos.forEach(function(t, i){ %>
      <%- include('partials/treatment-card', {
        title: t.nombre,
        price: t.precio,
        duration: t.tiempo,
        description: t.descripcion,
        tag: t.recomendado,
        imgSrc: t.img,
        imgSide: i % 2 === 0 ? 'right' : 'left'
      }) %>
    <% }) %>
  </section>

  <%- include('partials/cta-reserva') %>

  <div id="contacto"></div>
  <%- include('partials/footer') %>
</body>
</html>
